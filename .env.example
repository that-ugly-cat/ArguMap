# Copy this file to `.env` and fill in the values. Never commit `.env`.

# Anthropic API key — used by the LLM pipeline (auto-read by the anthropic SDK).
ANTHROPIC_API_KEY=sk-ant-...

# Secret used to sign JWT session tokens. Use a random string, min 32 chars.
# Generate one e.g. with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-a-random-string-min-32-chars
